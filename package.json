{
  "name": "mobiplus",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:store": "npm run dev --prefix storefront",
    "dev:admin": "npm run dev --prefix admin",
    "dev:api": "npm run dev --prefix api",
    "dev:all": "concurrently --kill-others -n \"API,STORE,ADMIN\" -c \"magenta,blue,cyan\" \"npm run dev:api\" \"npm run dev:store\" \"npm run dev:admin\"",
    "build": "npm run build --prefix storefront && cp -r storefront/dist ./dist",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@sentry/react": "^10.48.0",
    "@tanstack/react-query": "^5.97.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "framer-motion": "^12.38.0",
    "hono": "^4.12.12",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.454.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie": "^0.6.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prisma": "^6.2.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.4"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
